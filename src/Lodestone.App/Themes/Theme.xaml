<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ============================================================
         Design tokens — colours lifted verbatim from the prototype
         (Lodestone Mod Manager.dc.html). rgba() values are converted
         to #AARRGGBB.
         ============================================================ -->

    <!-- Surfaces -->
    <Color x:Key="WindowBgColor">#FF1C1C20</Color>
    <Color x:Key="NavBgColor">#FF171719</Color>
    <Color x:Key="ContentBgColor">#FF1E1E22</Color>
    <Color x:Key="CardBgColor">#FF26262B</Color>
    <Color x:Key="InputBgColor">#FF2A2A30</Color>
    <Color x:Key="ModalBgColor">#FF222227</Color>
    <Color x:Key="ToastBgColor">#FF2B2B31</Color>

    <!-- Accent -->
    <Color x:Key="AccentColor">#FF5AC26D</Color>
    <Color x:Key="AccentHoverColor">#FF6FCE80</Color>
    <Color x:Key="AccentTextColor">#FF10130F</Color>
    <Color x:Key="PinkColor">#FFE2719A</Color>
    <Color x:Key="DangerColor">#FFE2503F</Color>

    <!-- Text -->
    <Color x:Key="TextPrimaryColor">#FFF2F2F4</Color>
    <Color x:Key="TextBodyColor">#FFEDEDF0</Color>
    <Color x:Key="TextSecondaryColor">#FF9A9AA2</Color>
    <Color x:Key="TextMutedColor">#FF8E8E96</Color>
    <Color x:Key="TextFaintColor">#FF6A6A72</Color>
    <Color x:Key="TextLabelColor">#FF76767E</Color>

    <!-- Brushes: surfaces -->
    <SolidColorBrush x:Key="WindowBgBrush" Color="{StaticResource WindowBgColor}" />
    <SolidColorBrush x:Key="NavBgBrush" Color="{StaticResource NavBgColor}" />
    <SolidColorBrush x:Key="ContentBgBrush" Color="{StaticResource ContentBgColor}" />
    <SolidColorBrush x:Key="CardBgBrush" Color="{StaticResource CardBgColor}" />
    <SolidColorBrush x:Key="InputBgBrush" Color="{StaticResource InputBgColor}" />
    <SolidColorBrush x:Key="ModalBgBrush" Color="{StaticResource ModalBgColor}" />
    <SolidColorBrush x:Key="ToastBgBrush" Color="{StaticResource ToastBgColor}" />
    <SolidColorBrush x:Key="TitleBarBgBrush" Color="#03FFFFFF" />

    <!-- Brushes: borders (translucent white) -->
    <SolidColorBrush x:Key="BorderFaintBrush" Color="#0DFFFFFF" />
    <SolidColorBrush x:Key="BorderSubtleBrush" Color="#0FFFFFFF" />
    <SolidColorBrush x:Key="BorderStrongBrush" Color="#1AFFFFFF" />
    <SolidColorBrush x:Key="BorderHoverBrush" Color="#21FFFFFF" />

    <!-- Brushes: hover overlays -->
    <SolidColorBrush x:Key="HoverOverlayBrush" Color="#0BFFFFFF" />
    <SolidColorBrush x:Key="HoverOverlayStrongBrush" Color="#10FFFFFF" />
    <SolidColorBrush x:Key="ActiveOverlayBrush" Color="#0FFFFFFF" />

    <!-- Brushes: accent + status -->
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />
    <SolidColorBrush x:Key="AccentHoverBrush" Color="{StaticResource AccentHoverColor}" />
    <SolidColorBrush x:Key="AccentTextBrush" Color="{StaticResource AccentTextColor}" />
    <SolidColorBrush x:Key="AccentSoftBrush" Color="#245AC26D" />
    <SolidColorBrush x:Key="AccentFaintBrush" Color="#125AC26D" />
    <SolidColorBrush x:Key="PinkBrush" Color="{StaticResource PinkColor}" />
    <SolidColorBrush x:Key="PinkSoftBrush" Color="#29E2719A" />
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}" />
    <SolidColorBrush x:Key="DangerSoftBrush" Color="#24E2503F" />
    <SolidColorBrush x:Key="WarningBrush" Color="#FFE3B341" />
    <SolidColorBrush x:Key="WarningSoftBrush" Color="#24E3B341" />
    <SolidColorBrush x:Key="InfoBrush" Color="#FF5A91C2" />
    <SolidColorBrush x:Key="InfoSoftBrush" Color="#245A91C2" />

    <!-- Brushes: text -->
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}" />
    <SolidColorBrush x:Key="TextBodyBrush" Color="{StaticResource TextBodyColor}" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}" />
    <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMutedColor}" />
    <SolidColorBrush x:Key="TextFaintBrush" Color="{StaticResource TextFaintColor}" />
    <SolidColorBrush x:Key="TextLabelBrush" Color="{StaticResource TextLabelColor}" />

    <FontFamily x:Key="AppFont">Segoe UI Variable Display, Segoe UI Variable, Segoe UI</FontFamily>
    <FontFamily x:Key="MonoFont">Cascadia Mono, Consolas, ui-monospace</FontFamily>

    <!-- ============================================================
         Base text styles
         ============================================================ -->
    <Style x:Key="H1" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource AppFont}" />
        <Setter Property="FontSize" Value="26" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
    </Style>
    <Style x:Key="Subtitle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource AppFont}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>
    <Style x:Key="SectionLabel" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource AppFont}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{StaticResource TextLabelBrush}" />
        <Setter Property="Margin" Value="0,24,0,10" />
    </Style>

    <!-- Card container -->
    <Style x:Key="Card" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource CardBgBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderSubtleBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="12" />
    </Style>

    <!-- Slim scrollbars echoing the prototype -->
    <Style TargetType="ScrollBar">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Width" Value="11" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollBar">
                    <Grid Background="Transparent">
                        <Track x:Name="PART_Track" IsDirectionReversed="True">
                            <Track.Thumb>
                                <Thumb>
                                    <Thumb.Template>
                                        <ControlTemplate TargetType="Thumb">
                                            <Border Background="#22FFFFFF" CornerRadius="5" Margin="3,2" />
                                        </ControlTemplate>
                                    </Thumb.Template>
                                </Thumb>
                            </Track.Thumb>
                            <Track.IncreaseRepeatButton>
                                <RepeatButton Command="ScrollBar.PageDownCommand" Opacity="0" />
                            </Track.IncreaseRepeatButton>
                            <Track.DecreaseRepeatButton>
                                <RepeatButton Command="ScrollBar.PageUpCommand" Opacity="0" />
                            </Track.DecreaseRepeatButton>
                        </Track>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="Orientation" Value="Horizontal">
                <Setter Property="Height" Value="11" />
                <Setter Property="Width" Value="Auto" />
            </Trigger>
        </Style.Triggers>
    </Style>

</ResourceDictionary>
