<Window x:Class="Lodestone.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:views="clr-namespace:Lodestone.App.Views"
        Title="Lodestone — Mod Manager"
        Icon="pack://application:,,,/Assets/lodestone.ico"
        Width="1360" Height="880" MinWidth="940" MinHeight="600"
        WindowStartupLocation="CenterScreen" WindowStyle="None"
        Background="{StaticResource WindowBgBrush}"
        FontFamily="{StaticResource AppFont}" TextOptions.TextFormattingMode="Ideal"
        UseLayoutRounding="True">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="42" ResizeBorderThickness="6" CornerRadius="0" GlassFrameThickness="0" />
    </shell:WindowChrome.WindowChrome>

    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="42" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ===================== Title bar ===================== -->
        <Border Grid.Row="0" Background="{StaticResource TitleBarBgBrush}" BorderBrush="{StaticResource BorderFaintBrush}" BorderThickness="0,0,0,1">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0,0,0">
                    <Border Width="24" Height="24" CornerRadius="6" Background="{StaticResource AccentTileBrush}">
                        <Path Width="15" Height="15" Stretch="Uniform" Stroke="{StaticResource AccentTextBrush}" StrokeThickness="2"
                              StrokeLineJoin="Round" Data="M12 3 4 7v10l8 4 8-4V7z M4 7l8 4 8-4 M12 11v10" />
                    </Border>
                    <!-- Supporter badge sits before the title; rectangular corners (r6) match the adjacent logo tile -->
                    <Border Background="{StaticResource AccentSoftBrush}" CornerRadius="6" Padding="9,3" Margin="10,0,0,0" VerticalAlignment="Center"
                            Visibility="{Binding IsSupporter, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="Supporter" Foreground="{StaticResource AccentBrush}" FontSize="11" FontWeight="SemiBold" />
                    </Border>
                    <TextBlock Text="Lodestone" Foreground="{StaticResource TextPrimaryBrush}" FontSize="13" FontWeight="SemiBold" Margin="10,0,0,0" VerticalAlignment="Center" />
                    <TextBlock Text="Mod Manager" Foreground="{StaticResource TextFaintBrush}" FontSize="12" Margin="8,0,0,0" VerticalAlignment="Center" />
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="MinimizeButton" Style="{StaticResource CaptionButton}" Click="OnMinimize">
                        <Path Width="11" Height="11" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.2" Data="M1,6 L11,6" />
                    </Button>
                    <Button x:Name="MaximizeButton" Style="{StaticResource CaptionButton}" Click="OnMaximizeRestore">
                        <Border Width="10" Height="10" BorderBrush="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" BorderThickness="1.2" CornerRadius="1.5" />
                    </Button>
                    <Button x:Name="CloseButton" Style="{StaticResource CloseButton}" Click="OnClose">
                        <Path Width="11" Height="11" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.2" Data="M1.5,1.5 L10.5,10.5 M10.5,1.5 L1.5,10.5" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ===================== Body ===================== -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Nav rail -->
            <Border Grid.Column="0" Background="{StaticResource NavBgBrush}" BorderBrush="{StaticResource BorderFaintBrush}" BorderThickness="0,0,1,0">
                <DockPanel Margin="10,12">
                    <TextBlock DockPanel.Dock="Top" Text="LIBRARY" Style="{StaticResource SectionLabel}" Margin="12,6,12,10" FontSize="11" />
                    <RadioButton DockPanel.Dock="Top" Style="{StaticResource NavButton}" Command="{Binding GoHomeCommand}"
                                 IsChecked="{Binding Route, Converter={StaticResource Equals}, ConverterParameter=home, Mode=OneWay}">
                        <StackPanel Orientation="Horizontal">
                            <Path Width="19" Height="19" Stretch="Uniform" Stroke="#FFE6E6EA" StrokeThickness="1.7" StrokeLineJoin="Round" Data="M4 11 12 4l8 7 M6 10v9h12v-9 M10 19v-5h4v5" />
                            <TextBlock Text="Home" Margin="12,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </RadioButton>
                    <RadioButton DockPanel.Dock="Top" Style="{StaticResource NavButton}" Command="{Binding GoLibraryCommand}"
                                 IsChecked="{Binding Route, Converter={StaticResource Equals}, ConverterParameter=library, Mode=OneWay}">
                        <StackPanel Orientation="Horizontal">
                            <Path Width="19" Height="19" Stretch="Uniform" Stroke="#FFE6E6EA" StrokeThickness="1.7" StrokeLineJoin="Round" Data="M4 5h16 M4 11h16 M4 17h16" />
                            <TextBlock Text="My Content" Margin="12,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </RadioButton>

                    <TextBlock DockPanel.Dock="Top" Text="DISCOVER" Style="{StaticResource SectionLabel}" Margin="12,16,12,10" FontSize="11" />
                    <RadioButton DockPanel.Dock="Top" Style="{StaticResource NavButton}" Command="{Binding GoBrowseCommand}"
                                 IsChecked="{Binding Route, Converter={StaticResource Equals}, ConverterParameter=browse, Mode=OneWay}">
                        <StackPanel Orientation="Horizontal">
                            <Path Width="19" Height="19" Stretch="Uniform" Stroke="#FFE6E6EA" StrokeThickness="1.7" StrokeLineJoin="Round" Data="M12 3a9 9 0 1 0 0 18 9 9 0 0 0 0-18Z M15 9l-2.4 5.4L7 17l2.4-5.4L15 9Z" />
                            <TextBlock Text="Browse mods" Margin="12,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </RadioButton>

                    <!-- bottom group -->
                    <RadioButton DockPanel.Dock="Bottom" Style="{StaticResource NavButton}" Command="{Binding GoSettingsCommand}"
                                 IsChecked="{Binding Route, Converter={StaticResource Equals}, ConverterParameter=settings, Mode=OneWay}">
                        <StackPanel Orientation="Horizontal">
                            <Path Width="19" Height="19" Stretch="Uniform" Stroke="#FFE6E6EA" StrokeThickness="1.7" StrokeLineJoin="Round" Data="M4 7h9 M20 17h-9 M16.5 4.5a2.5 2.5 0 1 0 0 5 2.5 2.5 0 0 0 0-5Z M7.5 14.5a2.5 2.5 0 1 0 0 5 2.5 2.5 0 0 0 0-5Z" />
                            <TextBlock Text="Settings" Margin="12,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </RadioButton>
                    <RadioButton DockPanel.Dock="Bottom" Style="{StaticResource NavButton}" Command="{Binding GoDonateCommand}"
                                 IsChecked="{Binding Route, Converter={StaticResource Equals}, ConverterParameter=donate, Mode=OneWay}">
                        <StackPanel Orientation="Horizontal">
                            <Path Width="19" Height="19" Stretch="Uniform" Stroke="#FFE2719A" StrokeThickness="1.7" StrokeLineJoin="Round" Data="M12 20s-7-4.7-7-10a4 4 0 0 1 7-2.5A4 4 0 0 1 19 10c0 5.3-7 10-7 10Z" />
                            <TextBlock Text="Support us" Margin="12,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </RadioButton>
                    <Grid /> <!-- filler -->
                </DockPanel>
            </Border>

            <!-- Content -->
            <Grid Grid.Column="1" Background="{StaticResource ContentBgBrush}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- "Minecraft not detected" banner — blocks installs until a valid folder is set -->
                <Border Grid.Row="0" Background="#1FE3B341" BorderBrush="#55E3B341" BorderThickness="0,0,0,1" Padding="36,12"
                        Visibility="{Binding IsGameReady, Converter={StaticResource InvBoolToVis}}">
                    <Grid>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Path Width="18" Height="18" VerticalAlignment="Center" Stretch="Uniform" Stroke="{StaticResource WarningBrush}" StrokeThickness="1.9" StrokeLineJoin="Round" StrokeStartLineCap="Round" Data="M12 4l9 16H3z M12 10v4 M12 17h.01" />
                            <TextBlock Text="Minecraft not detected — set your game folder to install mods, packs and shaders." Foreground="#FFE9D9A8" FontSize="13" VerticalAlignment="Center" Margin="11,0,0,0" />
                        </StackPanel>
                        <Button Content="Locate Minecraft" Style="{StaticResource PrimaryButton}" HorizontalAlignment="Right" Command="{Binding LocateGameCommand}" />
                    </Grid>
                </Border>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <ContentControl Content="{Binding CurrentScreen}" />
                </ScrollViewer>

                <!-- Detail modal -->
                <views:DetailView Grid.RowSpan="2" DataContext="{Binding CurrentDetail}"
                                  Visibility="{Binding DataContext.IsModalOpen, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVis}}" />
            </Grid>
        </Grid>

        <!-- ===================== Overlays (span full window) ===================== -->
        <views:OnboardingView Grid.RowSpan="2" DataContext="{Binding Onboarding}"
                              Visibility="{Binding DataContext.ShowOnboarding, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVis}}" />

        <views:ToastHost Grid.RowSpan="2" DataContext="{Binding Toasts}" IsHitTestVisible="False"
                         VerticalAlignment="Bottom" HorizontalAlignment="Right" Margin="20" />

        <!-- ===================== Global activity bar ===================== -->
        <!-- A thin indeterminate bar + label at the very bottom while any install/loader operation runs.
             Collapsed (and not animating) when idle, so it costs nothing at rest. -->
        <Border Grid.Row="2" Background="{StaticResource TitleBarBgBrush}" BorderBrush="{StaticResource BorderFaintBrush}" BorderThickness="0,1,0,0"
                Visibility="{Binding Gate.IsBusy, Converter={StaticResource BoolToVis}}">
            <StackPanel>
                <ProgressBar Height="2.5" IsIndeterminate="{Binding Gate.IsBusy}"
                             Background="Transparent" BorderThickness="0" BorderBrush="Transparent" Foreground="{StaticResource AccentBrush}" />
                <StackPanel Orientation="Horizontal" Margin="36,8" VerticalAlignment="Center">
                    <Ellipse Width="8" Height="8" Fill="{StaticResource AccentBrush}" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding Gate.StatusLabel}" Foreground="{StaticResource TextBodyBrush}" FontSize="12.5" VerticalAlignment="Center" Margin="9,0,0,0" />
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>
