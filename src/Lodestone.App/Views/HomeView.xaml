<UserControl x:Class="Lodestone.App.Views.HomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:s="clr-namespace:Lodestone.App.Services"
             FontFamily="{StaticResource AppFont}">
    <Grid Margin="36,30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0">
            <TextBlock Text="Welcome back" Style="{StaticResource H1}" />
            <TextBlock Text="Drop a file below to install it instantly — no profiles, no config files, no fuss."
                       Style="{StaticResource Subtitle}" Margin="0,5,0,0" />
        </StackPanel>

        <!-- Stats -->
        <UniformGrid Grid.Row="1" Columns="4" Margin="0,24,0,0">
            <Border Style="{StaticResource Card}" Margin="0,0,7,0" Padding="18,16">
                <StackPanel>
                    <TextBlock Text="{Binding ModCount}" FontSize="30" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" />
                    <TextBlock Text="Mods installed" FontSize="12.5" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,0" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource Card}" Margin="7,0,7,0" Padding="18,16">
                <StackPanel>
                    <TextBlock Text="{Binding PackCount}" FontSize="30" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" />
                    <TextBlock Text="Resource packs" FontSize="12.5" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,0" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource Card}" Margin="7,0,7,0" Padding="18,16">
                <StackPanel>
                    <TextBlock Text="{Binding ShaderCount}" FontSize="30" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" />
                    <TextBlock Text="Shaders" FontSize="12.5" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,0" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource Card}" Margin="7,0,0,0" Padding="18,16">
                <StackPanel>
                    <TextBlock Text="{Binding ActiveVersion}" FontSize="30" FontWeight="Bold" Foreground="{StaticResource AccentBrush}" />
                    <TextBlock Text="Active version" FontSize="12.5" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,0" />
                </StackPanel>
            </Border>
        </UniformGrid>

        <!-- Drop zone -->
        <Border x:Name="DropZone" Grid.Row="2" Margin="0,22,0,0" MinHeight="210" CornerRadius="14" AllowDrop="True"
                Background="#05FFFFFF" BorderThickness="2" Cursor="Hand"
                DragEnter="OnDragEnter" DragOver="OnDragOver" DragLeave="OnDragLeave" Drop="OnDrop" MouseLeftButtonUp="OnDropZoneClick">
            <Border.BorderBrush>
                <SolidColorBrush Color="#29FFFFFF" />
            </Border.BorderBrush>
            <Border.Resources>
                <Style TargetType="Border" />
            </Border.Resources>
            <Grid>
                <!-- Idle -->
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                            Visibility="{Binding IsInstalling, Converter={StaticResource InvBoolToVis}}">
                    <Border Width="54" Height="54" CornerRadius="14" Background="{StaticResource AccentSoftBrush}" HorizontalAlignment="Center">
                        <Path Width="26" Height="26" Stretch="Uniform" Stroke="{StaticResource AccentBrush}" StrokeThickness="1.8" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Data="M12 16V4 M7 9l5-5 5 5 M5 20h14" />
                    </Border>
                    <TextBlock Text="Drag &amp; drop to install" FontSize="17" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Center" Margin="0,14,0,0" />
                    <TextBlock Text="Mods (.jar) · Resource packs &amp; shaders (.zip) — or click to browse files" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center" Margin="0,5,0,0" />
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,14,0,0">
                        <Border Background="#0DFFFFFF" BorderBrush="{StaticResource BorderStrongBrush}" BorderThickness="1" CornerRadius="8" Padding="10,4" Margin="4,0">
                            <TextBlock Text=".jar" FontSize="11.5" Foreground="{StaticResource TextBodyBrush}" />
                        </Border>
                        <Border Background="#0DFFFFFF" BorderBrush="{StaticResource BorderStrongBrush}" BorderThickness="1" CornerRadius="8" Padding="10,4" Margin="4,0">
                            <TextBlock Text=".zip" FontSize="11.5" Foreground="{StaticResource TextBodyBrush}" />
                        </Border>
                        <Border Background="#0DFFFFFF" BorderBrush="{StaticResource BorderStrongBrush}" BorderThickness="1" CornerRadius="8" Padding="10,4" Margin="4,0">
                            <TextBlock Text=".litemod" FontSize="11.5" Foreground="{StaticResource TextBodyBrush}" />
                        </Border>
                    </StackPanel>
                </StackPanel>

                <!-- Installing -->
                <StackPanel MaxWidth="460" VerticalAlignment="Center"
                            Visibility="{Binding IsInstalling, Converter={StaticResource BoolToVis}}">
                    <TextBlock FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}">
                        <Run Text="Installing " /><Run Text="{Binding InstallName, Mode=OneWay}" />
                    </TextBlock>
                    <TextBlock Text="{Binding InstallTypeLabel}" FontSize="12.5" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,0" />
                    <Border Height="7" CornerRadius="5" Background="#17FFFFFF" Margin="0,14,0,0">
                        <Border HorizontalAlignment="Stretch" CornerRadius="5" Background="{StaticResource AccentBrush}" />
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Recent + Updates -->
        <Grid Grid.Row="3" Margin="0,22,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.5*" />
                <ColumnDefinition Width="18" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>

            <!-- Both cards omit VerticalAlignment so they stretch to fill the row and stay equal height,
                 mirroring the design mock's `align-items:stretch`. The taller card sets the shared height. -->
            <Border Grid.Column="0" Style="{StaticResource Card}" Padding="20,18">
                <StackPanel>
                    <TextBlock Text="Recently added" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextBodyBrush}" Margin="0,0,0,12" />
                    <ItemsControl ItemsSource="{Binding RecentItems}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,9" >
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Width="34" Height="34" CornerRadius="9" Background="{Binding Name, Converter={StaticResource NameToColor}}">
                                        <TextBlock Text="{Binding AvatarLetter}" Foreground="White" FontWeight="Bold" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Name}" FontSize="13.5" FontWeight="Medium" Foreground="{StaticResource TextBodyBrush}" TextTrimming="CharacterEllipsis" />
                                        <TextBlock FontSize="11.5" Foreground="{StaticResource TextMutedBrush}">
                                            <Run Text="{Binding TypeLabel, Mode=OneWay}" /><Run Text=" · " /><Run Text="{Binding When, Mode=OneWay}" />
                                        </TextBlock>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                        <Ellipse Width="7" Height="7" VerticalAlignment="Center">
                                            <Ellipse.Style>
                                                <Style TargetType="Ellipse">
                                                    <Setter Property="Fill" Value="#FF6B6B73" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Enabled}" Value="True">
                                                            <Setter Property="Fill" Value="{StaticResource AccentBrush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Ellipse.Style>
                                        </Ellipse>
                                        <TextBlock Text="{Binding EnabledLabel}" FontSize="11.5" Foreground="{StaticResource TextSecondaryBrush}" Margin="6,0,0,0" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource Card}" Padding="20,18">
                <!-- Three-row layout so this card reads well when stretched to match a taller "Recently added":
                     header pinned top, the state region fills the slack, and "Check for updates" anchors to the
                     bottom edge. Mirrors the design mock, where the Updates card is a flex column. -->
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Updates" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextBodyBrush}" Margin="0,0,0,12" />

                    <!-- Pending updates: list + "Update all", kept at the top of the fill area. -->
                    <StackPanel Grid.Row="1" VerticalAlignment="Top" Visibility="{Binding HasUpdates, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="{Binding UpdatesLabel}" FontSize="12.5" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,10" />
                        <ItemsControl ItemsSource="{Binding UpdateItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="0,7">
                                        <Border Width="30" Height="30" CornerRadius="8" Background="{Binding Name, Converter={StaticResource NameToColor}}">
                                            <TextBlock Text="{Binding AvatarLetter}" Foreground="White" FontWeight="Bold" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                        <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="Medium" Foreground="{StaticResource TextBodyBrush}" />
                                            <TextBlock Text="{Binding Label}" FontSize="11" Foreground="{StaticResource TextMutedBrush}" />
                                        </StackPanel>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <Button Content="Update all" Style="{StaticResource PrimaryButton}" Command="{Binding UpdateAllCommand}" Margin="0,14,0,0" />
                    </StackPanel>

                    <!-- No updates: empty state centred in the fill area, matching the mock's justify-content:center. -->
                    <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,14"
                                Visibility="{Binding HasUpdates, Converter={StaticResource InvBoolToVis}}">
                        <Border Width="40" Height="40" CornerRadius="20" Background="{StaticResource AccentSoftBrush}" HorizontalAlignment="Center">
                            <Path Width="20" Height="20" Stretch="Uniform" Stroke="{StaticResource AccentBrush}" StrokeThickness="2.2" StrokeLineJoin="Round" StrokeStartLineCap="Round" Data="M5 12l4 4 10-10" />
                        </Border>
                        <TextBlock Text="{Binding UpdatesEmptyTitle}" FontSize="13.5" FontWeight="SemiBold" Foreground="{StaticResource TextBodyBrush}" HorizontalAlignment="Center" Margin="0,10,0,0" />
                        <TextBlock Text="{Binding UpdatesEmptySubtitle}" FontSize="12" Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" Margin="0,3,0,0" />
                    </StackPanel>

                    <!-- Manual check, always available, anchored to the card's bottom edge. -->
                    <Button Grid.Row="2" Style="{StaticResource SecondaryButton}" Command="{Binding CheckForUpdatesCommand}"
                            Content="{Binding CheckUpdatesLabel}" Margin="0,14,0,0"
                            IsEnabled="{Binding IsCheckingUpdates, Converter={StaticResource InvBool}}" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
