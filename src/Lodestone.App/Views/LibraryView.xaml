<UserControl x:Class="Lodestone.App.Views.LibraryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FontFamily="{StaticResource AppFont}">
    <UserControl.Resources>
        <!-- Dark, app-styled tooltip for the compatibility badges (scoped to this view; the rest of the
             app keeps the default tooltip). -->
        <Style x:Key="IssueToolTip" TargetType="ToolTip">
            <Setter Property="FontFamily" Value="{StaticResource AppFont}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="HasDropShadow" Value="False" />
            <Setter Property="MaxWidth" Value="320" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToolTip">
                        <Border Background="{StaticResource ToastBgBrush}" BorderBrush="{StaticResource BorderStrongBrush}"
                                BorderThickness="1" CornerRadius="9" Padding="12,9">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="24" ShadowDepth="5" Opacity="0.45" Color="Black" />
                            </Border.Effect>
                            <!-- A real TextBlock (not a ContentPresenter) so the message wraps and gets an explicit
                                 colour — a templated ContentPresenter would render the text black on this dark card. -->
                            <TextBlock Text="{TemplateBinding Content}" Foreground="{StaticResource TextBodyBrush}"
                                       FontSize="12.5" TextWrapping="Wrap" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- One compatibility badge = soft severity background + matching icon + short label. Error is the
             default; warning/info recolour via triggers on the bound issue's Severity. -->
        <Style x:Key="IssueBadgeBorder" TargetType="Border">
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="7,2" />
            <Setter Property="Margin" Value="0,2,6,2" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Background" Value="{StaticResource DangerSoftBrush}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Severity}" Value="Warning">
                    <Setter Property="Background" Value="{StaticResource WarningSoftBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Severity}" Value="Info">
                    <Setter Property="Background" Value="{StaticResource InfoSoftBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="IssueBadgeText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource DangerBrush}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Severity}" Value="Warning">
                    <Setter Property="Foreground" Value="{StaticResource WarningBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Severity}" Value="Info">
                    <Setter Property="Foreground" Value="{StaticResource InfoBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="IssueBadgeIcon" TargetType="Path">
            <Setter Property="Stroke" Value="{StaticResource DangerBrush}" />
            <!-- error: circle with an X -->
            <Setter Property="Data" Value="M12 3a9 9 0 1 0 0 18 9 9 0 0 0 0-18Z M9 9l6 6 M15 9l-6 6" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Severity}" Value="Warning">
                    <Setter Property="Stroke" Value="{StaticResource WarningBrush}" />
                    <!-- warning: triangle with an exclamation -->
                    <Setter Property="Data" Value="M12 4l9 16H3z M12 10v4 M12 17h.01" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Severity}" Value="Info">
                    <Setter Property="Stroke" Value="{StaticResource InfoBrush}" />
                    <!-- info: circle with an i -->
                    <Setter Property="Data" Value="M12 3a9 9 0 1 0 0 18 9 9 0 0 0 0-18Z M12 11v5 M12 8h.01" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- One "My Content" row. Shared by the flat list and each category section so the two stay identical. -->
        <DataTemplate x:Key="ContentItemTemplate">
            <Border Style="{StaticResource Card}" Margin="0,0,0,10" Padding="16,13" CornerRadius="11">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Width="42" Height="42" CornerRadius="10" ClipToBounds="True" Background="{Binding Name, Converter={StaticResource NameToColor}}">
                        <Grid>
                            <TextBlock Text="{Binding AvatarLetter}" Foreground="White" FontWeight="Bold" FontSize="17" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            <Image Source="{Binding IconUrl}" Stretch="UniformToFill" RenderOptions.BitmapScalingMode="HighQuality"
                                   Visibility="{Binding HasIcon, Converter={StaticResource BoolToVis}}" />
                        </Grid>
                    </Border>

                    <StackPanel Grid.Column="1" Margin="14,0,0,0" VerticalAlignment="Center">
                        <WrapPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding Name}" FontSize="14.5" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />

                            <!-- loader pill -->
                            <Border CornerRadius="8" Padding="8,2" Margin="9,0,0,0" Background="#1FFFFFFF" VerticalAlignment="Center"
                                    Visibility="{Binding HasLoader, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="{Binding LoaderLabel}" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextBodyBrush}" />
                            </Border>

                            <!-- update pill -->
                            <Border CornerRadius="8" Padding="8,2" Margin="6,0,0,0" Background="{DynamicResource AccentSoftBrush}" VerticalAlignment="Center"
                                    Visibility="{Binding UpdateAvailable, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="Update" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource AccentBrush}" />
                            </Border>

                            <!-- compatibility badges — one per issue, worst severity first. The short label sits on
                                 the badge; the full message is in the (dark) tooltip on hover. Badges wrap to the next
                                 line when the row runs out of width, so several never clip on narrow windows. -->
                            <ItemsControl ItemsSource="{Binding Issues}" Margin="6,0,0,0" VerticalAlignment="Center"
                                          Visibility="{Binding HasIssues, Converter={StaticResource BoolToVis}}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource IssueBadgeBorder}">
                                            <Border.ToolTip>
                                                <ToolTip Style="{StaticResource IssueToolTip}" Content="{Binding Message}" />
                                            </Border.ToolTip>
                                            <StackPanel Orientation="Horizontal">
                                                <Path Style="{StaticResource IssueBadgeIcon}" Width="12" Height="12" Stretch="Uniform"
                                                      StrokeThickness="1.8" StrokeLineJoin="Round" StrokeStartLineCap="Round" VerticalAlignment="Center" />
                                                <TextBlock Style="{StaticResource IssueBadgeText}" Text="{Binding ShortLabel}" Margin="5,0,0,0"
                                                           FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"
                                                           MaxWidth="220" TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </WrapPanel>
                        <TextBlock Text="{Binding MetaLabel}" FontSize="12" Foreground="{StaticResource TextMutedBrush}" Margin="0,3,0,0" />
                        <TextBlock Text="{Binding VersionsLabel}" FontSize="11" Foreground="{StaticResource TextFaintBrush}" Margin="0,3,0,0"
                                   Visibility="{Binding ShowVersions, Converter={StaticResource BoolToVis}}" />
                    </StackPanel>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <!-- Inline sorter for an adopted mod with no known version — pick the profile it belongs to. -->
                        <ComboBox Width="160" Style="{StaticResource DarkComboBox}" ItemContainerStyle="{StaticResource DarkComboBoxItem}"
                                  Margin="0,0,12,0" VerticalAlignment="Center"
                                  Visibility="{Binding CanAssign, Converter={StaticResource BoolToVis}}"
                                  ItemsSource="{Binding AssignTargets}" SelectedValuePath="Key"
                                  SelectedValue="{Binding AssignTargetKey, Mode=TwoWay}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Label}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <ToggleButton Style="{StaticResource ToggleSwitch}" IsChecked="{Binding Enabled, Mode=OneWay}" Command="{Binding ToggleCommand}" />
                        <Button Style="{StaticResource GhostButton}" Command="{Binding UninstallCommand}" Margin="14,0,0,0" ToolTip="Uninstall" Foreground="{StaticResource TextSecondaryBrush}">
                            <Path Width="17" Height="17" Stretch="Uniform" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.7" StrokeLineJoin="Round" StrokeStartLineCap="Round" Data="M4 7h16 M9 7V5h6v2 M6.5 7l.8 13h9.4l.8-13" />
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>
    </UserControl.Resources>
    <StackPanel Margin="36,30">

        <!-- Header + profile -->
        <Grid>
            <StackPanel>
                <TextBlock Text="My Content" Style="{StaticResource H1}" />
                <TextBlock Text="{Binding CountLabel}" Style="{StaticResource Subtitle}" Margin="0,4,0,0" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom">
                <TextBlock Text="Profile" FontSize="12.5" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center" Margin="0,0,10,0" />
                <ComboBox Width="200" Style="{StaticResource DarkComboBox}" ItemContainerStyle="{StaticResource DarkComboBoxItem}"
                          IsEnabled="{Binding Gate.IsIdle}"
                          ItemsSource="{Binding Profiles}"
                          SelectedValuePath="Key" SelectedValue="{Binding SelectedProfileKey, Mode=TwoWay}">
                    <!-- Explicit ItemTemplate (not DisplayMemberPath): the custom ComboBox template renders
                         SelectionBoxItem via SelectionBoxItemTemplate, which DisplayMemberPath doesn't populate,
                         so the closed box would otherwise fall back to ProfileOption.ToString(). -->
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Label}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </StackPanel>
        </Grid>

        <!-- Tabs + search -->
        <Grid Margin="0,20,0,0">
            <Border Style="{StaticResource SegmentBar}" HorizontalAlignment="Left">
                <StackPanel Orientation="Horizontal">
                    <RadioButton GroupName="LibTab" Style="{StaticResource Segment}" Content="Mods"
                                 IsChecked="{Binding LibTab, Converter={StaticResource Equals}, ConverterParameter=mods, Mode=TwoWay}" />
                    <RadioButton GroupName="LibTab" Style="{StaticResource Segment}" Content="Resource Packs"
                                 IsChecked="{Binding LibTab, Converter={StaticResource Equals}, ConverterParameter=resourcepacks, Mode=TwoWay}" />
                    <RadioButton GroupName="LibTab" Style="{StaticResource Segment}" Content="Shaders"
                                 IsChecked="{Binding LibTab, Converter={StaticResource Equals}, ConverterParameter=shaders, Mode=TwoWay}" />
                </StackPanel>
            </Border>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <!-- Category filter — built from the categories present on the current mods; hidden when
                     nothing is categorized (every item would read "Uncategorized"). On "All categories" the
                     list below groups itself into one section per category (issue #5). -->
                <ComboBox Width="170" Margin="0,0,12,0" VerticalAlignment="Center"
                          Style="{StaticResource DarkComboBox}" ItemContainerStyle="{StaticResource DarkComboBoxItem}"
                          Visibility="{Binding ShowCategoryFilter, Converter={StaticResource BoolToVis}}"
                          ItemsSource="{Binding Categories}"
                          SelectedValuePath="Key" SelectedValue="{Binding SelectedCategoryKey, Mode=TwoWay}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Label}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
                <Grid Width="230">
                    <TextBox Style="{StaticResource DarkTextBox}" Padding="33,9,12,9"
                             Text="{Binding LibSearch, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" />
                    <Path Width="15" Height="15" Margin="11,0,0,0" HorizontalAlignment="Left" VerticalAlignment="Center" IsHitTestVisible="False"
                          Stretch="Uniform" Stroke="{StaticResource TextMutedBrush}" StrokeThickness="1.8" StrokeStartLineCap="Round"
                          Data="M11 4a7 7 0 1 0 0 14 7 7 0 0 0 0-14Z M20 20l-3.5-3.5" />
                    <TextBlock Text="Search your content" Foreground="{StaticResource TextMutedBrush}" FontSize="13.5" Margin="33,0,0,0"
                               VerticalAlignment="Center" IsHitTestVisible="False">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding LibSearch}" Value="">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
            </StackPanel>
        </Grid>

        <!-- Loader gate: on the Mods tab, the selected loader isn't installed for this version yet, so the
             mods list is cleared and this banner explains it (mirrors Browse). Packs/shaders aren't gated. -->
        <Border Visibility="{Binding ShowLoaderGate, Converter={StaticResource BoolToVis}}"
                Background="#24E3B341" BorderBrush="{StaticResource WarningBrush}" BorderThickness="1"
                CornerRadius="11" Padding="14,11" Margin="0,18,0,0">
            <StackPanel Orientation="Horizontal">
                <Path Width="17" Height="17" VerticalAlignment="Center" Stretch="Uniform" Stroke="{StaticResource WarningBrush}" StrokeThickness="1.8"
                      StrokeLineJoin="Round" StrokeStartLineCap="Round" Data="M12 9v4 M12 17h.01 M10.3 4 3.3 16a2 2 0 0 0 1.7 3h14a2 2 0 0 0 1.7-3L13.7 4a2 2 0 0 0-3.4 0Z" />
                <TextBlock Text="{Binding LoaderGateMessage}" Foreground="{StaticResource WarningBrush}" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" Margin="10,0,0,0" />
            </StackPanel>
        </Border>

        <!-- List — flat, when a specific category is selected or there's nothing to group by. -->
        <ItemsControl ItemsSource="{Binding Items}" Margin="0,18,0,0"
                      ItemTemplate="{StaticResource ContentItemTemplate}"
                      Visibility="{Binding IsGrouped, Converter={StaticResource InvBoolToVis}}" />

        <!-- List — grouped into labelled category sections on "All categories" (issue #5). Each section is a
             big, greyed, uppercase header (the shared SectionLabel aesthetic) over its mods; non-collapsible. -->
        <ItemsControl ItemsSource="{Binding Sections}" Margin="0,10,0,0"
                      Visibility="{Binding IsGrouped, Converter={StaticResource BoolToVis}}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <StackPanel>
                        <TextBlock Text="{Binding Header}" Style="{StaticResource SectionLabel}" Margin="2,18,0,12" />
                        <ItemsControl ItemsSource="{Binding Items}" ItemTemplate="{StaticResource ContentItemTemplate}" />
                    </StackPanel>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- Empty -->
        <StackPanel HorizontalAlignment="Center" Margin="0,60" Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="Nothing here yet" FontSize="15" FontWeight="SemiBold" Foreground="#FFC7C7CC" HorizontalAlignment="Center" />
            <TextBlock Text="No items match this version or search. Try “All versions”, or drop a file on the Home tab." FontSize="13" Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Center" Margin="0,6,0,0" TextAlignment="Center" MaxWidth="380" TextWrapping="Wrap" />
        </StackPanel>
    </StackPanel>
</UserControl>
