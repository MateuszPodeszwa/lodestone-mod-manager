<UserControl x:Class="Lodestone.App.Views.BrowseView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FontFamily="{StaticResource AppFont}">
    <UserControl.Resources>
        <!-- Flat card-as-button so clicking a card opens its detail modal. -->
        <Style x:Key="CardButton" TargetType="Button">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="{StaticResource CardBgBrush}" CornerRadius="12" Padding="16"
                                BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="BorderBrush" Value="{StaticResource AccentBorderBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <StackPanel Margin="36,30">
        <!-- Header + source -->
        <Grid>
            <StackPanel>
                <TextBlock Text="Browse mods" Style="{StaticResource H1}" />
                <TextBlock Style="{StaticResource Subtitle}" Margin="0,4,0,0">
                    <Run Text="{Binding ResultCountLabel, Mode=OneWay}" /><Run Text=" · one-click install to your library" />
                </TextBlock>
            </StackPanel>
            <Border Style="{StaticResource SegmentBar}" HorizontalAlignment="Right" VerticalAlignment="Bottom">
                <StackPanel Orientation="Horizontal">
                    <RadioButton GroupName="Source" Style="{StaticResource Segment}" Content="Modrinth"
                                 IsChecked="{Binding BrowseSource, Converter={StaticResource Equals}, ConverterParameter=modrinth, Mode=TwoWay}" />
                    <RadioButton GroupName="Source" Style="{StaticResource Segment}" Content="CurseForge"
                                 IsEnabled="{Binding IsCurseForgeAvailable}"
                                 ToolTip="Configure a CurseForge API key to enable this source (see docs/HANDOFF.md)."
                                 IsChecked="{Binding BrowseSource, Converter={StaticResource Equals}, ConverterParameter=curseforge, Mode=TwoWay}" />
                </StackPanel>
            </Border>
        </Grid>

        <!-- Search + sort -->
        <Grid Margin="0,20,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Grid Grid.Column="0">
                <TextBox Style="{StaticResource DarkTextBox}" Padding="38,11,14,11" FontSize="14"
                         Text="{Binding BrowseQuery, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" />
                <Path Width="16" Height="16" Margin="13,0,0,0" HorizontalAlignment="Left" VerticalAlignment="Center" IsHitTestVisible="False"
                      Stretch="Uniform" Stroke="{StaticResource TextMutedBrush}" StrokeThickness="1.8" StrokeStartLineCap="Round"
                      Data="M11 4a7 7 0 1 0 0 14 7 7 0 0 0 0-14Z M20 20l-3.5-3.5" />
                <TextBlock Text="Search mods, packs and shaders" Foreground="{StaticResource TextMutedBrush}" FontSize="14" Margin="38,0,0,0"
                           VerticalAlignment="Center" IsHitTestVisible="False">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding BrowseQuery}" Value="">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>
            <ComboBox Grid.Column="2" Width="170" Style="{StaticResource DarkComboBox}"
                      SelectedValuePath="Tag" SelectedValue="{Binding BrowseSort, Mode=TwoWay}">
                <ComboBox.Resources>
                    <Style TargetType="ComboBoxItem" BasedOn="{StaticResource DarkComboBoxItem}" />
                </ComboBox.Resources>
                <ComboBoxItem Content="Relevance" Tag="relevance" />
                <ComboBoxItem Content="Most downloaded" Tag="downloads" />
                <ComboBoxItem Content="Most followed" Tag="followers" />
            </ComboBox>
        </Grid>

        <!-- Categories -->
        <WrapPanel Margin="0,16,0,0">
            <RadioButton GroupName="Cat" Style="{StaticResource CategoryPill}" Content="All" IsChecked="{Binding BrowseCat, Converter={StaticResource Equals}, ConverterParameter=all, Mode=TwoWay}" />
            <RadioButton GroupName="Cat" Style="{StaticResource CategoryPill}" Content="Performance" IsChecked="{Binding BrowseCat, Converter={StaticResource Equals}, ConverterParameter=optimization, Mode=TwoWay}" />
            <RadioButton GroupName="Cat" Style="{StaticResource CategoryPill}" Content="Utility" IsChecked="{Binding BrowseCat, Converter={StaticResource Equals}, ConverterParameter=utility, Mode=TwoWay}" />
            <RadioButton GroupName="Cat" Style="{StaticResource CategoryPill}" Content="Library" IsChecked="{Binding BrowseCat, Converter={StaticResource Equals}, ConverterParameter=library, Mode=TwoWay}" />
            <RadioButton GroupName="Cat" Style="{StaticResource CategoryPill}" Content="Tech" IsChecked="{Binding BrowseCat, Converter={StaticResource Equals}, ConverterParameter=tech, Mode=TwoWay}" />
            <RadioButton GroupName="Cat" Style="{StaticResource CategoryPill}" Content="Adventure" IsChecked="{Binding BrowseCat, Converter={StaticResource Equals}, ConverterParameter=adventure, Mode=TwoWay}" />
            <RadioButton GroupName="Cat" Style="{StaticResource CategoryPill}" Content="Shaders" IsChecked="{Binding BrowseCat, Converter={StaticResource Equals}, ConverterParameter=shaders, Mode=TwoWay}" />
            <RadioButton GroupName="Cat" Style="{StaticResource CategoryPill}" Content="Resource Packs" IsChecked="{Binding BrowseCat, Converter={StaticResource Equals}, ConverterParameter=resource-packs, Mode=TwoWay}" />
        </WrapPanel>

        <!-- Loader gate: mods can't be installed until their loader is set up for the active version. -->
        <Border Visibility="{Binding ShowLoaderGate, Converter={StaticResource BoolToVis}}"
                Background="#24E3B341" BorderBrush="{StaticResource WarningBrush}" BorderThickness="1"
                CornerRadius="11" Padding="14,11" Margin="0,16,0,0">
            <StackPanel Orientation="Horizontal">
                <Path Width="17" Height="17" VerticalAlignment="Center" Stretch="Uniform" Stroke="{StaticResource WarningBrush}" StrokeThickness="1.8"
                      StrokeLineJoin="Round" StrokeStartLineCap="Round" Data="M12 9v4 M12 17h.01 M10.3 4 3.3 16a2 2 0 0 0 1.7 3h14a2 2 0 0 0 1.7-3L13.7 4a2 2 0 0 0-3.4 0Z" />
                <TextBlock Text="{Binding LoaderGateMessage}" Foreground="{StaticResource WarningBrush}" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" Margin="10,0,0,0" />
            </StackPanel>
        </Border>

        <!-- Loading: a spinner stands in for the result list while the source responds to a search/filter. -->
        <StackPanel HorizontalAlignment="Center" Margin="0,80" MinHeight="200"
                    Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
            <Control Style="{StaticResource Spinner}" HorizontalAlignment="Center" />
            <TextBlock Text="Searching…" FontSize="13.5" Foreground="{StaticResource TextMutedBrush}"
                       HorizontalAlignment="Center" Margin="0,16,0,0" />
        </StackPanel>

        <!-- Results, pager and empty-state swap out for the spinner while a search is in flight. -->
        <StackPanel Visibility="{Binding IsLoading, Converter={StaticResource InvBoolToVis}}">
        <!-- Results -->
        <ItemsControl ItemsSource="{Binding Results}" Margin="0,20,0,0">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Columns="2" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Button Style="{StaticResource CardButton}" Command="{Binding OpenCommand}" Margin="7">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Width="48" Height="48" CornerRadius="11" ClipToBounds="True" Background="{Binding Name, Converter={StaticResource NameToColor}}">
                                    <Grid>
                                        <TextBlock Text="{Binding AvatarLetter}" Foreground="White" FontWeight="Bold" FontSize="19" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        <Image Source="{Binding IconUrl}" Stretch="UniformToFill" RenderOptions.BitmapScalingMode="HighQuality"
                                               Visibility="{Binding HasIcon, Converter={StaticResource BoolToVis}}" />
                                    </Grid>
                                </Border>
                                <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Name}" FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{Binding AuthorLabel}" FontSize="12" Foreground="{StaticResource TextMutedBrush}" Margin="0,2,0,0" />
                                </StackPanel>
                            </Grid>
                            <TextBlock Text="{Binding Description}" FontSize="12.5" Foreground="#FFA6A6AE" TextWrapping="Wrap" MaxHeight="40" Margin="0,11,0,0" TextTrimming="CharacterEllipsis" />
                            <ItemsControl ItemsSource="{Binding Chips}" Margin="0,11,0,0">
                                <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#0DFFFFFF" BorderBrush="#12FFFFFF" BorderThickness="1" CornerRadius="8" Padding="9,3" Margin="0,0,6,0">
                                            <TextBlock Text="{Binding}" FontSize="11" Foreground="{StaticResource TextBodyBrush}" />
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <Border BorderBrush="{StaticResource BorderFaintBrush}" BorderThickness="0,1,0,0" Margin="0,13,0,0" Padding="0,12,0,0">
                                <Grid>
                                    <StackPanel Orientation="Horizontal">
                                        <Path Width="13" Height="13" VerticalAlignment="Center" Stretch="Uniform" Stroke="{StaticResource TextSecondaryBrush}" StrokeThickness="1.8" StrokeLineJoin="Round" StrokeStartLineCap="Round" Data="M12 4v11 M7 11l5 5 5-5 M5 20h14" />
                                        <TextBlock Text="{Binding Downloads}" FontSize="11.5" Foreground="{StaticResource TextSecondaryBrush}" Margin="4,0,14,0" VerticalAlignment="Center" />
                                        <Path Width="13" Height="13" VerticalAlignment="Center" Stretch="Uniform" Stroke="{StaticResource TextSecondaryBrush}" StrokeThickness="1.8" StrokeLineJoin="Round" Data="M12 20s-7-4.7-7-10a4 4 0 0 1 7-2.5A4 4 0 0 1 19 10c0 5.3-7 10-7 10Z" />
                                        <TextBlock Text="{Binding Followers}" FontSize="11.5" Foreground="{StaticResource TextSecondaryBrush}" Margin="4,0,0,0" VerticalAlignment="Center" />
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Visibility="{Binding Installed, Converter={StaticResource BoolToVis}}">
                                        <Path Width="14" Height="14" VerticalAlignment="Center" Stretch="Uniform" Stroke="{StaticResource AccentBrush}" StrokeThickness="2.4" StrokeLineJoin="Round" StrokeStartLineCap="Round" Data="M5 12l4 4 10-10" />
                                        <TextBlock Text="Installed" FontSize="12.5" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}" Margin="5,0,0,0" VerticalAlignment="Center" />
                                    </StackPanel>
                                    <Button Content="Install" Style="{StaticResource PrimaryButton}" HorizontalAlignment="Right" Padding="16,7"
                                            Command="{Binding InstallCommand}" Visibility="{Binding CanInstall, Converter={StaticResource BoolToVis}}"
                                            IsEnabled="{Binding DataContext.CanInstallHere, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            ToolTip="Set your Minecraft folder and install its loader first" />
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Button>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- Pagination -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0"
                    Visibility="{Binding HasPages, Converter={StaticResource BoolToVis}}">
            <Button Content="‹ Prev" Style="{StaticResource SecondaryButton}" Command="{Binding PrevPageCommand}" IsEnabled="{Binding CanPrev}" Margin="0,0,8,0" />
            <ItemsControl ItemsSource="{Binding PageNumbers}" VerticalAlignment="Center">
                <ItemsControl.ItemsPanel><ItemsPanelTemplate><StackPanel Orientation="Horizontal" /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button Content="{Binding}" MinWidth="36" Margin="2,0" Padding="8,7" Style="{StaticResource SecondaryButton}"
                                Command="{Binding DataContext.GoToPageCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                CommandParameter="{Binding}" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
            <Button Content="Next ›" Style="{StaticResource SecondaryButton}" Command="{Binding NextPageCommand}" IsEnabled="{Binding CanNext}" Margin="8,0,0,0" />
        </StackPanel>

        <!-- Empty -->
        <StackPanel HorizontalAlignment="Center" Margin="0,60" Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="No results" FontSize="15" FontWeight="SemiBold" Foreground="#FFC7C7CC" HorizontalAlignment="Center" />
            <TextBlock Text="Try a different search, category or source." FontSize="13" Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Center" Margin="0,6,0,0" />
        </StackPanel>
        </StackPanel>
    </StackPanel>
</UserControl>
