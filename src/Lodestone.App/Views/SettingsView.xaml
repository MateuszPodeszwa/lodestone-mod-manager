<UserControl x:Class="Lodestone.App.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FontFamily="{StaticResource AppFont}">
    <StackPanel Margin="36,30" MaxWidth="1040" HorizontalAlignment="Stretch">
        <TextBlock Text="Settings" Style="{StaticResource H1}" />
        <TextBlock Text="Everything Lodestone needs — and nothing it doesn’t." Style="{StaticResource Subtitle}" Margin="0,4,0,0" />

        <!-- GAME -->
        <TextBlock Text="GAME" Style="{StaticResource SectionLabel}" />
        <Border Style="{StaticResource Card}">
            <StackPanel>
                <Grid Margin="18,16">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Game directory" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextBodyBrush}" />
                        <TextBlock Text="{Binding GameDir, TargetNullValue='Not set yet'}" FontSize="12" Foreground="{StaticResource TextMutedBrush}" FontFamily="{StaticResource MonoFont}" Margin="0,3,0,0" TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                    <Button Content="Change…" Style="{StaticResource SecondaryButton}" HorizontalAlignment="Right" Command="{Binding ChangeDirCommand}" />
                </Grid>
                <Border BorderBrush="{StaticResource BorderFaintBrush}" BorderThickness="0,1,0,0">
                    <Grid Margin="18,16">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Default mod loader" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextBodyBrush}" />
                            <TextBlock Text="Used when installing mods that support more than one." FontSize="12" Foreground="{StaticResource TextMutedBrush}" Margin="0,3,0,0" />
                        </StackPanel>
                        <Border Style="{StaticResource SegmentBar}" Background="#FF1F1F23" HorizontalAlignment="Right"
                                IsEnabled="{Binding CanManageLoaders}" ToolTip="Set your Minecraft folder first">
                            <StackPanel Orientation="Horizontal">
                                <RadioButton GroupName="Loader" Style="{StaticResource Segment}" Content="Fabric" IsChecked="{Binding Loader, Converter={StaticResource Equals}, ConverterParameter=fabric, Mode=TwoWay}" />
                                <RadioButton GroupName="Loader" Style="{StaticResource Segment}" Content="Forge" IsChecked="{Binding Loader, Converter={StaticResource Equals}, ConverterParameter=forge, Mode=TwoWay}" />
                                <RadioButton GroupName="Loader" Style="{StaticResource Segment}" Content="Quilt" IsChecked="{Binding Loader, Converter={StaticResource Equals}, ConverterParameter=quilt, Mode=TwoWay}" />
                                <RadioButton GroupName="Loader" Style="{StaticResource Segment}" Content="NeoForge" IsChecked="{Binding Loader, Converter={StaticResource Equals}, ConverterParameter=neoforge, Mode=TwoWay}" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>
                <Border BorderBrush="{StaticResource BorderFaintBrush}" BorderThickness="0,1,0,0">
                    <Grid Margin="18,16">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Loader version" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextBodyBrush}" />
                            <!-- Left-aligned so MaxWidth doesn't centre it (a Stretch element clamped by MaxWidth
                                 is centred by WPF, which looked like a large left margin under the title). -->
                            <TextBlock Text="{Binding LoaderHintText}" FontSize="12" Foreground="{StaticResource TextMutedBrush}" Margin="0,3,0,0" TextWrapping="Wrap" MaxWidth="430" HorizontalAlignment="Left" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" IsEnabled="{Binding CanManageLoaders}">
                            <TextBlock Text="Minecraft" FontSize="12.5" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center" Margin="0,0,10,0" />
                            <ComboBox Width="120" Style="{StaticResource DarkComboBox}" ItemContainerStyle="{StaticResource DarkComboBoxItem}"
                                      ItemsSource="{Binding GameVersions}" SelectedItem="{Binding LoaderGameVersion, Mode=TwoWay}" Margin="0,0,10,0" />
                            <!-- Manual "check again"; disappears once the loader is detected as installed. -->
                            <Button Style="{StaticResource GhostButton}" Command="{Binding RefreshLoaderStatusCommand}" Margin="0,0,8,0" ToolTip="Check again"
                                    Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"
                                    Visibility="{Binding ShowLoaderRefresh, Converter={StaticResource BoolToVis}}">
                                <Path Width="15" Height="15" Stretch="Uniform" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.7"
                                      StrokeLineJoin="Round" StrokeStartLineCap="Round" Data="M23 4v6h-6 M20.49 15a9 9 0 1 1-2.12-9.36L23 10" />
                            </Button>
                            <!-- Detected install status for the selected loader + version — the truth, not just what's selected. -->
                            <TextBlock Text="{Binding LoaderStatusLabel}" FontSize="12.5" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,12,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsActiveLoaderInstalled}" Value="True">
                                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <Button Content="{Binding LoaderActionLabel}" Style="{StaticResource SecondaryButton}"
                                    Command="{Binding UpdateLoaderCommand}" />
                        </StackPanel>
                    </Grid>
                </Border>
            </StackPanel>
        </Border>

        <!-- MODS & UPDATES -->
        <TextBlock Text="MODS &amp; UPDATES" Style="{StaticResource SectionLabel}" />
        <Border Style="{StaticResource Card}">
            <StackPanel>
                <Grid Margin="18,16">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Auto-update mods" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextBodyBrush}" />
                        <TextBlock Text="Keep enabled mods on the latest compatible version." FontSize="12" Foreground="{StaticResource TextMutedBrush}" Margin="0,3,0,0" />
                    </StackPanel>
                    <ToggleButton Style="{StaticResource ToggleSwitch}" HorizontalAlignment="Right" IsChecked="{Binding AutoUpdate, Mode=TwoWay}" />
                </Grid>
                <Border BorderBrush="{StaticResource BorderFaintBrush}" BorderThickness="0,1,0,0">
                    <Grid Margin="18,16">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Notify me about updates" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextBodyBrush}" />
                            <TextBlock Text="Show a badge on Home when updates are available." FontSize="12" Foreground="{StaticResource TextMutedBrush}" Margin="0,3,0,0" />
                        </StackPanel>
                        <ToggleButton Style="{StaticResource ToggleSwitch}" HorizontalAlignment="Right" IsChecked="{Binding Notify, Mode=TwoWay}" />
                    </Grid>
                </Border>
                <Border BorderBrush="{StaticResource BorderFaintBrush}" BorderThickness="0,1,0,0">
                    <Grid Margin="18,16">
                        <StackPanel VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Early access" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextBodyBrush}" />
                                <Border Background="{StaticResource AccentSoftBrush}" CornerRadius="8" Padding="7,2" Margin="9,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="SUPPORTER" FontSize="9.5" FontWeight="Bold" Foreground="{StaticResource AccentBrush}" />
                                </Border>
                            </StackPanel>
                            <TextBlock Text="Get beta builds before everyone else. Unlocked for supporters." FontSize="12" Foreground="{StaticResource TextMutedBrush}" Margin="0,3,0,0" />
                        </StackPanel>
                        <ToggleButton Style="{StaticResource ToggleSwitch}" HorizontalAlignment="Right" IsChecked="{Binding EarlyAccess, Mode=TwoWay}"
                                      IsEnabled="{Binding CanUseEarlyAccess}" ToolTip="Unlocked for supporters" />
                    </Grid>
                </Border>
                <Border BorderBrush="{StaticResource BorderFaintBrush}" BorderThickness="0,1,0,0">
                    <Grid Margin="18,16">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Concurrent downloads" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextBodyBrush}" />
                            <TextBlock Text="How many files to download at the same time." FontSize="12" Foreground="{StaticResource TextMutedBrush}" Margin="0,3,0,0" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <Button Content="−" Style="{StaticResource SecondaryButton}" Width="30" Height="30" Padding="0" FontSize="17" Command="{Binding DecreaseConcurrentCommand}" />
                            <TextBlock Text="{Binding Concurrent}" FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" MinWidth="22" TextAlignment="Center" VerticalAlignment="Center" Margin="10,0" />
                            <Button Content="+" Style="{StaticResource SecondaryButton}" Width="30" Height="30" Padding="0" FontSize="17" Command="{Binding IncreaseConcurrentCommand}" />
                        </StackPanel>
                    </Grid>
                </Border>
            </StackPanel>
        </Border>

        <!-- APPEARANCE -->
        <TextBlock Text="APPEARANCE" Style="{StaticResource SectionLabel}" />
        <Border Style="{StaticResource Card}">
            <Grid Margin="18,16">
                <StackPanel VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Accent colour" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextBodyBrush}" />
                        <Border Background="{StaticResource AccentSoftBrush}" CornerRadius="8" Padding="7,2" Margin="9,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="SUPPORTER" FontSize="9.5" FontWeight="Bold" Foreground="{StaticResource AccentBrush}" />
                        </Border>
                    </StackPanel>
                    <TextBlock Text="Personalise the app. Extra colours are unlocked for supporters." FontSize="12" Foreground="{StaticResource TextMutedBrush}" Margin="0,3,0,0" />
                </StackPanel>
                <ItemsControl ItemsSource="{Binding Accents}" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <ItemsControl.ItemsPanel><ItemsPanelTemplate><StackPanel Orientation="Horizontal" /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Width="34" Height="34" Margin="6,0,0,0" Cursor="Hand" ToolTip="{Binding Name}"
                                    Command="{Binding DataContext.SelectAccentCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                    CommandParameter="{Binding}">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Grid>
                                            <Ellipse Stroke="{StaticResource AccentBrush}" StrokeThickness="2"
                                                     Visibility="{Binding IsSelected, Converter={StaticResource BoolToVis}}" />
                                            <Ellipse Fill="{Binding Swatch}" Margin="4" />
                                            <Ellipse Fill="#AA15151A" Margin="4"
                                                     Visibility="{Binding IsLocked, Converter={StaticResource BoolToVis}}" />
                                        </Grid>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </Border>

        <!-- SOURCES & APP -->
        <TextBlock Text="SOURCES &amp; APP" Style="{StaticResource SectionLabel}" />
        <Border Style="{StaticResource Card}">
            <StackPanel>
                <Grid Margin="18,16">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Use CurseForge as fallback" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextBodyBrush}" />
                        <TextBlock Text="Modrinth is searched first; fall back to CurseForge when needed." FontSize="12" Foreground="{StaticResource TextMutedBrush}" Margin="0,3,0,0" />
                    </StackPanel>
                    <ToggleButton Style="{StaticResource ToggleSwitch}" HorizontalAlignment="Right" IsChecked="{Binding CurseFallback, Mode=TwoWay}"
                                  IsEnabled="{Binding IsCurseForgeAvailable}" ToolTipService.ShowOnDisabled="True"
                                  ToolTip="Configure a CurseForge API key to enable this source (see docs/HANDOFF.md)." />
                </Grid>
                <Border BorderBrush="{StaticResource BorderFaintBrush}" BorderThickness="0,1,0,0">
                    <Grid Margin="18,16">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Close to system tray" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextBodyBrush}" />
                            <TextBlock Text="Keep Lodestone running in the background when closed." FontSize="12" Foreground="{StaticResource TextMutedBrush}" Margin="0,3,0,0" />
                        </StackPanel>
                        <ToggleButton Style="{StaticResource ToggleSwitch}" HorizontalAlignment="Right" IsChecked="{Binding CloseToTray, Mode=TwoWay}" />
                    </Grid>
                </Border>
                <Border BorderBrush="{StaticResource BorderFaintBrush}" BorderThickness="0,1,0,0">
                    <Grid Margin="18,16">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{Binding AppVersionLabel}" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextBodyBrush}" />
                            <TextBlock Text="Free &amp; lightweight · made for the Minecraft community." FontSize="12" Foreground="{StaticResource TextMutedBrush}" Margin="0,3,0,0" />
                        </StackPanel>
                        <Button Content="Check for updates" Style="{StaticResource SecondaryButton}" HorizontalAlignment="Right" Command="{Binding CheckUpdatesCommand}" />
                    </Grid>
                </Border>
                <Border BorderBrush="{StaticResource BorderFaintBrush}" BorderThickness="0,1,0,0">
                    <Grid Margin="18,16">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Logs" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextBodyBrush}" />
                            <TextBlock Text="Open the folder with Lodestone’s diagnostic logs — handy when reporting a bug." FontSize="12" Foreground="{StaticResource TextMutedBrush}" Margin="0,3,0,0" />
                        </StackPanel>
                        <Button Content="Open logs" Style="{StaticResource SecondaryButton}" HorizontalAlignment="Right" Command="{Binding OpenLogsCommand}" />
                    </Grid>
                </Border>
                <Border BorderBrush="{StaticResource BorderFaintBrush}" BorderThickness="0,1,0,0">
                    <Grid Margin="18,16">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Reset to clean" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextBodyBrush}" />
                            <TextBlock Text="Remove every mod and Fabric/Quilt loader Lodestone installed — back to vanilla. Your worlds are kept." FontSize="12" Foreground="{StaticResource TextMutedBrush}" Margin="0,3,0,0" />
                        </StackPanel>
                        <Button Content="Reset…" Style="{StaticResource SecondaryButton}" HorizontalAlignment="Right" Command="{Binding ResetToCleanCommand}" />
                    </Grid>
                </Border>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
