<UserControl x:Class="Lodestone.App.Views.OnboardingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FontFamily="{StaticResource AppFont}">
    <Grid Background="#D60D0E11">
        <Border Width="520" Background="{StaticResource ModalBgBrush}" CornerRadius="18" Padding="34"
                BorderBrush="{StaticResource BorderStrongBrush}" BorderThickness="1"
                VerticalAlignment="Center" HorizontalAlignment="Center">
            <StackPanel>
                <!-- Step 0 -->
                <StackPanel Visibility="{Binding IsStep0, Converter={StaticResource BoolToVis}}" HorizontalAlignment="Center">
                    <Border Width="64" Height="64" CornerRadius="17" HorizontalAlignment="Center" Background="{StaticResource AccentTileBrush}">
                        <Path Width="34" Height="34" Stretch="Uniform" Stroke="{StaticResource AccentTextBrush}" StrokeThickness="2" StrokeLineJoin="Round" Data="M12 3 4 7v10l8 4 8-4V7z M4 7l8 4 8-4 M12 11v10" />
                    </Border>
                    <TextBlock Text="Welcome to Lodestone" FontSize="23" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Center" Margin="0,18,0,0" />
                    <TextBlock Text="The simplest way to install and manage your Minecraft mods, resource packs and shaders. No config files, ever." FontSize="14" Foreground="{StaticResource TextSecondaryBrush}" TextAlignment="Center" TextWrapping="Wrap" Margin="0,8,0,0" />
                </StackPanel>

                <!-- Step 1 -->
                <StackPanel Visibility="{Binding IsStep1, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="Your Minecraft folder" FontSize="21" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Center" />
                    <TextBlock Text="Detected automatically — change it if you keep mods elsewhere." FontSize="14" Foreground="{StaticResource TextSecondaryBrush}" TextAlignment="Center" Margin="0,7,0,0"
                               Visibility="{Binding IsGameDetected, Converter={StaticResource BoolToVis}}" />
                    <TextBlock Text="We couldn't find it automatically — choose your .minecraft folder to continue." FontSize="14" Foreground="{StaticResource TextSecondaryBrush}" TextAlignment="Center" TextWrapping="Wrap" Margin="0,7,0,0"
                               Visibility="{Binding IsGameDetected, Converter={StaticResource InvBoolToVis}}" />
                    <Border Background="{StaticResource AccentFaintBrush}" BorderBrush="{StaticResource AccentBorderBrush}" BorderThickness="1" CornerRadius="11" Padding="16,14" Margin="0,20,0,0">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="30" Height="30" CornerRadius="15" Background="{StaticResource AccentSoftBrush}">
                                <Path Width="16" Height="16" Stretch="Uniform" Stroke="{StaticResource AccentBrush}" StrokeThickness="2.4" StrokeLineJoin="Round" StrokeStartLineCap="Round" Data="M5 12l4 4 10-10" />
                            </Border>
                            <StackPanel Margin="11,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="Minecraft (Java Edition)" FontSize="13" FontWeight="SemiBold" Foreground="#FFE6E6EA" />
                                <TextBlock Text="{Binding GameDir}" FontSize="11.5" Foreground="{StaticResource TextMutedBrush}" FontFamily="{StaticResource MonoFont}" TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    <Button Content="Choose folder…" Style="{StaticResource SecondaryButton}" HorizontalAlignment="Center" Margin="0,12,0,0" Command="{Binding LocateCommand}" />
                </StackPanel>

                <!-- Step 2 -->
                <StackPanel Visibility="{Binding IsStep2, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="A couple of preferences" FontSize="21" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Center" />
                    <TextBlock Text="You can change these any time in Settings." FontSize="14" Foreground="{StaticResource TextSecondaryBrush}" TextAlignment="Center" Margin="0,7,0,0" />
                    <TextBlock Text="Default mod loader" FontSize="13" FontWeight="SemiBold" Foreground="#FFDCDCE0" Margin="0,20,0,9" />
                    <Border Style="{StaticResource SegmentBar}" Background="#FF1F1F23" HorizontalAlignment="Stretch">
                        <UniformGrid Columns="4">
                            <RadioButton GroupName="ObLoader" Style="{StaticResource Segment}" Content="Fabric" IsChecked="{Binding ObLoader, Converter={StaticResource Equals}, ConverterParameter=fabric, Mode=TwoWay}" />
                            <RadioButton GroupName="ObLoader" Style="{StaticResource Segment}" Content="Forge" IsChecked="{Binding ObLoader, Converter={StaticResource Equals}, ConverterParameter=forge, Mode=TwoWay}" />
                            <RadioButton GroupName="ObLoader" Style="{StaticResource Segment}" Content="Quilt" IsChecked="{Binding ObLoader, Converter={StaticResource Equals}, ConverterParameter=quilt, Mode=TwoWay}" />
                            <RadioButton GroupName="ObLoader" Style="{StaticResource Segment}" Content="NeoForge" IsChecked="{Binding ObLoader, Converter={StaticResource Equals}, ConverterParameter=neoforge, Mode=TwoWay}" />
                        </UniformGrid>
                    </Border>
                    <Border Background="#08FFFFFF" BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1" CornerRadius="11" Padding="16,14" Margin="0,18,0,0">
                        <Grid>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Keep my mods up to date" FontSize="13.5" FontWeight="SemiBold" Foreground="#FFE6E6EA" />
                                <TextBlock Text="Auto-update enabled mods to the latest compatible build." FontSize="11.5" Foreground="{StaticResource TextMutedBrush}" Margin="0,2,0,0" />
                            </StackPanel>
                            <ToggleButton Style="{StaticResource ToggleSwitch}" HorizontalAlignment="Right" IsChecked="{Binding ObAuto, Mode=TwoWay}" />
                        </Grid>
                    </Border>
                </StackPanel>

                <!-- Step 3 -->
                <StackPanel Visibility="{Binding IsStep3, Converter={StaticResource BoolToVis}}" HorizontalAlignment="Center">
                    <Border Width="64" Height="64" CornerRadius="32" Background="{StaticResource AccentSoftBrush}" HorizontalAlignment="Center">
                        <Path Width="34" Height="34" Stretch="Uniform" Stroke="{StaticResource AccentBrush}" StrokeThickness="2.2" StrokeLineJoin="Round" StrokeStartLineCap="Round" Data="M5 12l4 4 10-10" />
                    </Border>
                    <TextBlock Text="You're all set!" FontSize="23" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Center" Margin="0,18,0,0" />
                    <TextBlock Text="Drag a mod onto the window to install it instantly — or browse thousands of mods right inside the app." FontSize="14" Foreground="{StaticResource TextSecondaryBrush}" TextAlignment="Center" TextWrapping="Wrap" Margin="0,8,0,0" />
                </StackPanel>

                <!-- Dots -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,26,0,0">
                    <Border Width="22" Height="5" CornerRadius="3" Margin="3,0" Background="{StaticResource AccentBrush}" />
                    <Border Width="22" Height="5" CornerRadius="3" Margin="3,0">
                        <Border.Style><Style TargetType="Border"><Setter Property="Background" Value="#2EFFFFFF" /><Style.Triggers><DataTrigger Binding="{Binding Dot1}" Value="True"><Setter Property="Background" Value="{StaticResource AccentBrush}" /></DataTrigger></Style.Triggers></Style></Border.Style>
                    </Border>
                    <Border Width="22" Height="5" CornerRadius="3" Margin="3,0">
                        <Border.Style><Style TargetType="Border"><Setter Property="Background" Value="#2EFFFFFF" /><Style.Triggers><DataTrigger Binding="{Binding Dot2}" Value="True"><Setter Property="Background" Value="{StaticResource AccentBrush}" /></DataTrigger></Style.Triggers></Style></Border.Style>
                    </Border>
                    <Border Width="22" Height="5" CornerRadius="3" Margin="3,0">
                        <Border.Style><Style TargetType="Border"><Setter Property="Background" Value="#2EFFFFFF" /><Style.Triggers><DataTrigger Binding="{Binding Dot3}" Value="True"><Setter Property="Background" Value="{StaticResource AccentBrush}" /></DataTrigger></Style.Triggers></Style></Border.Style>
                    </Border>
                </StackPanel>

                <!-- Buttons -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,22,0,0">
                    <Button Content="Skip" Style="{StaticResource GhostButton}" Foreground="{StaticResource TextSecondaryBrush}" Padding="18,11" Command="{Binding SkipCommand}"
                            Visibility="{Binding NotLast, Converter={StaticResource BoolToVis}}" />
                    <Button Content="{Binding NextLabel}" Style="{StaticResource PrimaryButton}" Padding="28,11" Margin="12,0,0,0" Command="{Binding NextCommand}" />
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
