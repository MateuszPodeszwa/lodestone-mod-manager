# ----- Build output -----
[Bb]in/
[Oo]bj/
[Oo]ut/
publish/
artifacts/
TestResults/
*.user
*.suo
*.userprefs

# ----- Velopack / release output -----
# Anchored to the repo root: vpk pack writes ./Releases here. Unanchored "Releases/"
# also matched website/server/api/releases/ (case-insensitive on Windows), which silently
# kept the changelog API routes out of git. Keep this rooted so it only hits build output.
/Releases/
*.nupkg.bak

# ----- IDE / OS -----
.vs/
.idea/
*.DotSettings.user
.vscode/*
!.vscode/extensions.json
Thumbs.db
.DS_Store

# ----- Local agent / tooling state (do not publish) -----
.claude/

# ----- Local secrets / signing material (NEVER commit) -----
*.snk
*.pfx
secrets/
keys/

# ----- Coverage -----
coverage/
*.coverage
*.cobertura.xml
