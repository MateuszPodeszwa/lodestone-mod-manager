# ─────────────────────────────────────────────────────────────────────────
# Lodestone website — environment variables
# Copy to `.env` for local dev; set these in Railway → Variables for production.
# ─────────────────────────────────────────────────────────────────────────

# Session cookie encryption (required by nuxt-auth-utils). 32+ random chars.
# Generate one with:  openssl rand -base64 32
NUXT_SESSION_PASSWORD=please-change-me-to-a-long-random-string-32+

# ── Supporter code signing ───────────────────────────────────────────────
# The PKCS#8 ECDSA P-256 PRIVATE key (base64, single line) that matches the
# public key embedded in the app. This is the contents of keys/supporter.private.b64.
# WITHOUT this, the site can verify patrons but cannot mint redeemable codes.
NUXT_SUPPORTER_PRIVATE_KEY_B64=

# Optional: the matching PUBLIC key. Used only to self-verify signatures at boot.
# Defaults to the app's embedded key, so you normally don't need to set this.
# NUXT_SUPPORTER_PUBLIC_KEY_B64=

# ── Patreon OAuth ────────────────────────────────────────────────────────
# Create a client at https://www.patreon.com/portal/registration/register-clients
# Redirect URI must EXACTLY match the one registered with Patreon.
NUXT_PATREON_CLIENT_ID=
NUXT_PATREON_CLIENT_SECRET=
NUXT_PATREON_REDIRECT_URI=https://lodestonemc.net/api/auth/patreon/callback
# Optional: restrict eligibility to your campaign. Blank = accept any membership Patreon returns.
NUXT_PATREON_CAMPAIGN_ID=
# Count former/declined patrons as supporters too (the app counts "any tier, current or former").
NUXT_PATREON_ALLOW_FORMER=true
# Owner/teammate allowlist (comma-separated). A campaign owner is NOT a patron of their own
# campaign, so anyone listed here is treated as a supporter AND skips the beta cent threshold
# below. Match on either the Patreon numeric user id or the Patreon login email (case-insensitive).
NUXT_PATREON_OWNER_IDS=
NUXT_PATREON_OWNER_EMAILS=podinatubie@gmail.com
# Pledge (cents) at/above which beta early-access unlocks. 700 = $7 Supporter tier.
# Owners (above) are exempt from this threshold.
NUXT_BETA_THRESHOLD_CENTS=700

# ── GitHub (releases / changelog / downloads) ────────────────────────────
NUXT_GITHUB_REPO=MateuszPodeszwa/LodestoneModManager
# Optional token — only raises the anonymous API rate limit. Repo is public, so not required.
NUXT_GITHUB_TOKEN=

# ── Database (Railway Postgres) ──────────────────────────────────────────
# Railway's Postgres plugin injects DATABASE_URL automatically. For local dev,
# point this at any Postgres instance. If unset, the site runs without persistence.
DATABASE_URL=

# ── Public ───────────────────────────────────────────────────────────────
NUXT_PUBLIC_SITE_URL=https://lodestonemc.net
